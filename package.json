{
  "name": "dwatcher",
  "private": true,
  "description": "Dog Watcher — Android mobile app for canine surveillance and behavior monitoring",
  "scripts": {
    "lint": "pnpm -r lint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf {} + && find . -name '.turbo' -type d -prune -exec rm -rf {} +",
    "android": "pnpm --filter @dwatcher/mobile expo run:android",
    "ios": "pnpm --filter @dwatcher/mobile expo run:ios"
  },
  "engines": {
    "node": "24.15.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.1.0",
  "pnpm": {
    "overrides": {
      "metro": "0.83.3",
      "metro-core": "0.83.3",
      "metro-config": "0.83.3",
      "metro-resolver": "0.83.3",
      "metro-runtime": "0.83.3",
      "metro-babel-transformer": "0.83.3",
      "metro-cache": "0.83.3",
      "metro-cache-key": "0.83.3",
      "metro-file-map": "0.83.3",
      "metro-minify-terser": "0.83.3",
      "metro-source-map": "0.83.3",
      "metro-symbolicate": "0.83.3",
      "metro-transform-plugins": "0.83.3",
      "metro-transform-worker": "0.83.3"
    },
    "packageExtensions": {
      "@expo/cli": {
        "peerDependencies": {
          "metro": "*",
          "metro-core": "*",
          "metro-config": "*",
          "metro-resolver": "*",
          "metro-runtime": "*"
        }
      },
      "@expo/metro-config": {
        "peerDependencies": {
          "metro": "*",
          "metro-cache": "*",
          "metro-config": "*"
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.5.0"
  }
}
