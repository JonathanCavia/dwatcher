{
  "name": "dwatcher",
  "private": true,
  "description": "Dog Watcher — Android mobile app for canine surveillance and behavior monitoring",
  "scripts": {
    "lint": "pnpm -r lint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf {} + && find . -name '.turbo' -type d -prune -exec rm -rf {} +"
  },
  "engines": {
    "node": "24.15.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.1.0",
  "pnpm": {
    "overrides": {
      "metro": "~0.83.0",
      "metro-core": "~0.83.0",
      "metro-config": "~0.83.0",
      "metro-resolver": "~0.83.0",
      "metro-runtime": "~0.83.0",
      "metro-babel-transformer": "~0.83.0",
      "metro-cache": "~0.83.0",
      "metro-cache-key": "~0.83.0",
      "metro-file-map": "~0.83.0",
      "metro-minify-terser": "~0.83.0",
      "metro-source-map": "~0.83.0",
      "metro-symbolicate": "~0.83.0",
      "metro-transform-plugins": "~0.83.0",
      "metro-transform-worker": "~0.83.0"
    },
    "packageExtensions": {
      "@expo/cli": {
        "peerDependencies": {
          "metro": "*",
          "metro-core": "*",
          "metro-config": "*",
          "metro-resolver": "*",
          "metro-runtime": "*"
        }
      },
      "@expo/metro-config": {
        "peerDependencies": {
          "metro": "*",
          "metro-cache": "*",
          "metro-config": "*"
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.5.0"
  }
}
