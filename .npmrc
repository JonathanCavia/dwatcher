# pnpm configuration for React Native / Expo monorepo
strict-peer-dependencies=false
auto-install-peers=true

# Expo SDK 52 + Metro deep-import internal sub-packages (metro-core,
# metro-config, metro-resolver, metro-transform-plugins, etc.) that
# aren't declared as dependencies. shamefully-hoist creates a flat
# node_modules the same way npm/yarn do, which is what Expo expects.
shamefully-hoist=true
