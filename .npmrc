# pnpm configuration — strict resolution for monorepo consistency
strict-peer-dependencies=true
auto-install-peers=true
hoist=false
shamefully-hoist=false

# Expo SDK 52 + @expo/cli deep-import metro sub-packages (metro-core,
# metro-config, metro-resolver, etc.). These packages aren't declared
# as dependencies of @expo/cli but are required at runtime.
public-hoist-pattern[]=*metro*
