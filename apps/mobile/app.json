{
  "expo": {
    "name": "dwatcher",
    "slug": "dwatcher",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dwatcher",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "backgroundColor": "#1a1a2e"
    },
    "android": {
      "package": "com.dwatcher.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MICROPHONE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "POST_NOTIFICATIONS"
      ]
    },
    "platforms": [
      "android"
    ],
    "plugins": [
      "expo-router",
      "expo-dev-client"
    ],
    "ios": {
      "bundleIdentifier": "com.dwatcher.app"
    }
  }
}
