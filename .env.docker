# ── Docker Compose environment variables ──────────────────────
# Copy to .env and adjust for your machine.

# Backend
BACKEND_PORT=3000
SIGNALING_PORT=3001
JWT_SECRET=change-me-in-production
TURN_SECRET=change-me-in-production

# PostgreSQL
POSTGRES_PORT=5432

# pgAdmin (optional, use `docker compose --profile tools up`)
PGADMIN_PORT=5050
PGADMIN_PASSWORD=admin

# Coturn / TURN (optional, use `docker compose --profile webrtc up`)
TURN_PORT=3478
